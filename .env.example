# NoCodeGit (nocodegit.tech) — copy to .env.local
# NEVER commit real secrets.

# Required: 32+ character secret for session JWT + field encryption
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
NOCODEGIT_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# Public site URL (production: https://nocodegit.tech)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Data directories (SQLite + code snapshots)
NOCODEGIT_DATA_DIR=./data
NOCODEGIT_DATABASE_PATH=./data/nocodegit.sqlite
NOCODEGIT_STORAGE_PATH=./data/snapshots

# NODE_ENV=production

# --- Resend (transactional email) ---
# Create API key: https://resend.com/api-keys
RESEND_API_KEY=re_...
EMAIL_FROM=NoCodeGit <noreply@nocodegit.tech>

# --- Razorpay Pro (optional — free plan works without) ---
# Payment Button (Dashboard → Payment Buttons → embed) — preferred simple upgrade UI
RAZORPAY_PAYMENT_BUTTON_ID=pl_TEe7YulzKyTjLb
# Optional: API keys + subscription plan for programmatic checkout
# Dashboard → API Keys + Subscriptions → create a monthly plan (e.g. ₹500)
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...
RAZORPAY_PLAN_PRO=plan_...
# Webhook secret for subscription.* + payment.captured → POST /api/billing/webhook
RAZORPAY_WEBHOOK_SECRET=...

# --- Optional S3 / Cloudflare R2 snapshots (falls back to local disk) ---
# S3_BUCKET=nocodegit-snapshots
# S3_ENDPOINT=https://xxx.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PREFIX=snapshots
