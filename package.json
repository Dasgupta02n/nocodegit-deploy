{
  "name": "nocodegit",
  "version": "1.1.0",
  "private": true,
  "description": "NoCodeGit (nocodegit.tech) — Save. Ship. Still. Version vault + deploy to your host. Free 300MB; Pro $5/mo unlimited + ads editor.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "tray:install": "npm --prefix tray install",
    "tray": "npm --prefix tray start",
    "deploy:hostinger:ps1": "powershell -ExecutionPolicy Bypass -File scripts/hostinger-deploy.ps1",
    "test": "node tests/core.test.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1089.0",
    "archiver": "^7.0.1",
    "bcryptjs": "^3.0.2",
    "better-sqlite3": "^12.11.1",
    "jose": "^6.0.11",
    "next": "^15.5.2",
    "razorpay": "^2.9.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^6.17.2",
    "ssh2": "^1.17.0",
    "uuid": "^11.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/archiver": "^6.0.3",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ssh2": "^1.15.5",
    "@types/uuid": "^10.0.0",
    "concurrently": "^10.0.3",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "eslint": "^9",
    "eslint-config-next": "^15.5.2",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.23.1",
    "typescript": "^5",
    "wait-on": "^9.0.10"
  },
  "engines": {
    "node": ">=20"
  },
  "allowScripts": {
    "ssh2@1.17.0": true
  }
